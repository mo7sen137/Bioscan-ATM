# اخفاء الـ HTML من الحسبة عشان ما تسيطرش على الشريط
*.html linguist-documentation=true

# التأكد من أن جيت هاب يتعرف على أكواد الهاردوير كـ C++
*.ino linguist-language=cpp
*.cpp linguist-language=cpp
*.h linguist-language=cpp

# لو عندك ملفات جافا سكريبت منفصلة تأكد من تفعيلها
*.js linguist-detectable=true
